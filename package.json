{
  "name": "signal-loom",
  "private": true,
  "version": "0.9.7",
  "description": "A studio for generative media: node-based Flow, a layered Image editor, print/comic Paper layout, and a Video timeline — local-first, bring-your-own-key.",
  "license": "SEE LICENSE IN LICENSE",
  "author": {
    "name": "Sloom Software",
    "email": "support@sloom.studio"
  },
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "dashboard": "node ops/dev-dashboard/dashboard.mjs",
    "electron": "node electron/launcher.cjs",
    "electron:dev": "node electron/launcher.cjs --dev",
    "electron:preview": "node electron/launcher.cjs",
    "generate:comic-panels": "node scripts/headless-comic-panel-art.mjs",
    "place:comic-panels": "node scripts/place-comic-panels-in-paper.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:smoke": "vitest run src/lib/appSmoke.test.ts",
    "smoke:native": "node scripts/native-smoke.mjs",
    "smoke:native:video-render": "node scripts/native-video-render-smoke.mjs",
    "smoke:native:paper:pdf-parity": "node scripts/native-paper-pdf-parity.mjs",
    "smoke:native:project": "node scripts/native-real-project-smoke.mjs",
    "smoke:native:project:soak": "node scripts/native-real-project-soak.mjs",
    "smoke:native:stress": "node scripts/native-smoke.mjs --stress",
    "gate:local": "node scripts/release-gate.mjs local",
    "gate:native": "node scripts/release-gate.mjs native",
    "gate:android-localdream": "node scripts/android-localdream-gate.mjs",
    "setup:android-localdream": "node scripts/android-localdream-setup.mjs",
    "gate:release": "node scripts/release-gate.mjs release",
    "android:prepare-localdream-runtime": "node scripts/prepare-android-localdream-runtime.mjs",
    "sync:catalog": "node scripts/sync-provider-catalog.mjs",
    "sync:android": "npm run build && cap sync android",
    "build:android": "npm run android:prepare-localdream-runtime && npm run sync:android && cd android && ./gradlew assembleDebug",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "dist:mac:zip": "npm run build && electron-builder --mac zip",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb",
    "icons:mac": "bash scripts/create-mac-icon.sh",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@google/genai": "^1.50.1",
    "@google/generative-ai": "^0.24.1",
    "@huggingface/inference": "^4.13.15",
    "@xyflow/react": "^12.10.2",
    "ag-psd": "^30.1.1",
    "clsx": "^2.1.1",
    "dbus-next": "^0.10.2",
    "fabric": "^7.3.1",
    "fflate": "^0.8.3",
    "lucide-react": "^1.8.0",
    "openai": "^6.34.0",
    "peerjs": "^1.5.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "spectral.js": "^3.0.0",
    "tailwind-merge": "^3.5.0",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.31",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/fabric": "^5.3.11",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.15.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "googleapis": "^173.0.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "studio.sloom.signalloom",
    "productName": "Signal Loom",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "shared/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "ops/native-render",
        "to": "ops/native-render",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "category": "public.app-category.graphics-design",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/mac/entitlements.mac.plist",
      "entitlementsInherit": "build/mac/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "category": "AudioVideo",
      "icon": "build/icons/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
