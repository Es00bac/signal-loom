# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Local configuration and credentials
.env
.env.*
!.env.example
*.pem
*.key

# Persistent local Electron test profile (native-real-project-video-render-parity.mjs and
# friends) — has a dev-test license key baked into its (encrypted-at-rest) local storage.
# Machine-local only, never shared, never committed.
.test-profile/
*.p12
*.pfx

# nginx server configs — operator/server infra, not source. Keep out of the
# public repo (they disclose server paths/hostnames; live copies stay on the VPS).
nginx-*.conf
ops/remote-access/nginx/*.conf

# Local runtime state, browser automation artifacts, and generated output
.codex
.cache
.omc
.playwright-cli
.playwright-mcp
coverage
output
scratch
*.sloom
*.signal-loom-scratch

# Local development notes can contain machine paths, deployment hostnames,
# and other operator-specific context that should not be published by default.
docs/notes
docs/superpowers

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Packaging and build output
/release/
/test-results/

# Generated dev-dashboard snapshots
ops/dev-dashboard/artifacts/

# Scratch QA screenshots (repo root)
/dashboard-static-checklists-current-1920x1080.png
/image-layer-transform-warp-before-1920x1080.png
/paper-mobile-source-drawer-handle-mcp.png
/sloom-studio-live-desktop-1920x1080-posthardening.png
/sloom-studio-live-mobile-412x915-posthardening.png

# Large desktop build artifacts staged for site deploy (not source)
docs/release/website/sloom-studio/downloads/*.exe
docs/release/website/sloom-studio/downloads/*.AppImage
docs/release/website/sloom-studio/downloads/*.deb
docs/release/website/sloom-studio/downloads/*.blockmap

# Proprietary mobile build artifacts — NEVER commit. The Android APK is a sold product and
# AABs are Play Store uploads; anyone who wants the build can compile it themselves. Local
# copies stay on disk (for VPS deploy / Play upload) but are kept out of git entirely.
*.apk
*.aab

# Loose QA/screenshot artifacts dumped at repo root (not project files)
/*.png
/*.jpeg
