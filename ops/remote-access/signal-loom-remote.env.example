# Copy this file to ~/.config/signal-loom-remote.env and replace every value.
# Do not commit the real file.

SIGNAL_LOOM_AGENT_TOKEN=change-me-to-a-long-random-token
SIGNAL_LOOM_TUNNEL_SSH_KEY=/home/you/.ssh/signal_loom_vps
SIGNAL_LOOM_TUNNEL_USER=your-vps-user
SIGNAL_LOOM_TUNNEL_HOST=your-vps.example.com
SIGNAL_LOOM_PREVIEW_PORT=4174
